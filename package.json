{
  "name": "product-hunt-backend",
  "version": "1.0.0",
  "description": "Product Hunt Backend API (Node.js, Express, TypeScript)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation tsx watch index.ts",
    "build": "tsc",
    "start": "node --no-deprecation dist/index.js"
  },
  "keywords": [
    "node",
    "express",
    "typescript",
    "mongodb",
    "jwt"
  ],
  "author": "Eiasin",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.4.0",
    "mongoose": "^9.1.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.19",
    "@types/nodemailer": "^7.0.9",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
